  <% if(typeof errors != 'undefined' && errors.length>0) {%>
              <div class="bg-red-300 border text-red-500 p-4 px-6 mb-4 rounded relative" role="alert">
                <strong class="font-bold">Error!</strong>
                <span class="">
                  <% errors.forEach(error => { %> 
                    <li class=""><%= error %></li>
                  <% }); %>
              </div>
            <% } %>
